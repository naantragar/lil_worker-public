# ============================================================
# lil_worker — configuration template
# Copy this file to .env and fill in real values
# NEVER commit .env to git
# ============================================================

# Telegram Bot Token (get from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Allowed Telegram user IDs (comma-separated, no spaces)
# Get your ID from @userinfobot
ALLOWED_USERS=123456789,987654321

# Claude model to use
# Options: sonnet | opus | haiku
CLAUDE_MODEL=sonnet

# OpenAI model for voice transcription (optional)
# Used if voice message transcription is enabled
OPENAI_VOICE_MODEL=gpt-4o-mini-transcribe

# OpenAI API key (only needed if voice transcription is enabled)
# OPENAI_API_KEY=sk-...
